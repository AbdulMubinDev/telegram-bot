# Use this when running in Docker. Copy to .env and fill in your secrets.
# Paths below are for inside the container; the ./data folder on the host is mounted at /app/data.

# Telegram (from https://my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Bot (from @BotFather)
BOT_TOKEN=1234567890:ABCdef...

# Channels
SOURCE_CHANNEL=sourcechannel
DEST_CHANNEL_ID=-100XXXXXXXXXX

# Google Drive staging (optional — set USE_DRIVE_STAGING=true to enable)
# Most users should leave this off (direct mode: source TG → local → destination TG)
USE_DRIVE_STAGING=false
# DRIVE_ROOT_FOLDER_ID=your_root_folder_id
# CREDENTIALS_PATH=/app/data/credentials.json

# Paths (Docker: all under mounted volume /app/data — do not change these)
TEMP_DIR=/app/data/temp
STATE_FILE=/app/data/state.json
LOG_FILE=/app/data/logs/agent.log

# Admin panel: your Telegram user ID from @userinfobot (comma-separated for multiple)
ADMIN_USER_IDS=123456789
