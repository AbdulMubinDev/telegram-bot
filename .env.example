# Telegram (from https://my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Bot (from @BotFather; used only for posting to destination channel)
BOT_TOKEN=1234567890:ABCdef...

# Channels
SOURCE_CHANNEL=sourcechannel
DEST_CHANNEL_ID=-100XXXXXXXXXX

# Google Drive staging (optional — set USE_DRIVE_STAGING=true to enable)
# Most users should leave this off (direct mode: source TG → local → destination TG)
USE_DRIVE_STAGING=false
# DRIVE_ROOT_FOLDER_ID=your_root_folder_id
# CREDENTIALS_PATH=/path/to/credentials.json

# Paths relative to project root (telegram-bot/) — work on any OS (Django-style BASE_DIR)
TEMP_DIR=data/temp
STATE_FILE=data/state.json
LOG_FILE=data/logs/agent.log

# Admin panel (optional): comma-separated Telegram user IDs allowed to send bot commands
# Get your ID from @userinfobot. Leave empty to disable admin commands.
# ADMIN_USER_IDS=123456789,987654321
